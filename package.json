{
  "name": "@cynerad/hooks",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.10.0",
  "description": "Collection of hooks for react projects.",
  "author": "javad gharibi",
  "license": "MIT",
  "keywords": [
    "react",
    "typescript",
    "hooks"
